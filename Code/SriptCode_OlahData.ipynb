   "source": [
    "# PREPROCESSING\n",
    "\n",
    "# =========================\n",
    "# IMPORT LIBRARY\n",
    "# =========================\n",
    "import pandas as pd\n",
    "import re\n",
    "from Sastrawi.Stemmer.StemmerFactory import StemmerFactory\n",
    "from Sastrawi.StopWordRemover.StopWordRemoverFactory import StopWordRemoverFactory\n",
    "import nltk\n",
    "from nltk.corpus import stopwords\n",
    "\n",
    "nltk.download('stopwords')\n",
    "\n",
    "# =========================\n",
    "# LOAD DATA \n",
    "# =========================\n",
    "df = pd.read_csv(\n",
    "    r\"D:\\KULIAH\\SKRIPSI\\data\\aespa_labeling.csv\",\n",
    "    sep=';',\n",
    "    encoding='utf-8-sig'\n",
    ")   # data sudah melalui tahap pengumpulan - sampling - pelabelan\n",
    "\n",
    "# hapus data full_text kosong\n",
    "df = df.dropna(subset=[\"full_text\"])\n",
    "\n",
    "print(df.shape)\n",
    "print(df.columns)\n",
    "\n",
    "# =========================\n",
    "# CASE FOLDING\n",
    "# =========================\n",
    "def case_folding(text):\n",
    "    text = str(text).lower()   # ubah semua huruf menjadi lowercase\n",
    "\n",
    "    return text\n",
    "\n",
    "# =========================\n",
    "# CLEANING\n",
    "# =========================\n",
    "def cleaning(text):\n",
    "\n",
    "    text = re.sub(r\"http\\S+|www\\S+\", \"\", text) # hapus URL\n",
    "    text = re.sub(r\"@\\w+\", \"\", text)           # hapus mention\n",
    "    text = re.sub(r\"#\", \"\", text)              # hapus simbol hashtag (#) saja\n",
    "    text = re.sub(r\"[^a-zA-Z\\s]\", \" \", text)   # hanya menyisakan huruf latin\n",
    "    text = re.sub(r\"\\s+\", \" \", text).strip()   # hapus spasi berlebih\n",
    "\n",
    "    return text\n",
    "\n",
    "# =========================\n",
    "# TOKENIZATION\n",
    "# =========================\n",
    "def tokenization(text):\n",
    "\n",
    "    tokens = text.split()   # memecah kalimat menjadi token/kata\n",
    "\n",
    "    return tokens\n",
    "\n",
    "# =========================\n",
    "# STOPWORD\n",
    "# =========================\n",
    "factory = StopWordRemoverFactory()\n",
    "\n",
    "stopwords_id = set(factory.get_stop_words())   # stopword Bahasa Indonesia\n",
    "stopwords_en = set(stopwords.words(\"english\")) # stopword Bahasa Inggris\n",
    "custom_words = {\"aespa\", \"spa\", \"amp\"}         # kata tambahan yang ingin dihapus\n",
    "\n",
    "all_stopwords = stopwords_id.union(stopwords_en).union(custom_words)\n",
    "# gabungkan seluruh stopword\n",
    "\n",
    "# =========================\n",
    "# STOPWORD REMOVAL\n",
    "# =========================\n",
    "def remove_stopwords(tokens):\n",
    "\n",
    "    filtered = [\n",
    "        word for word in tokens\n",
    "        if word not in all_stopwords\n",
    "    ]   # buang token yang termasuk stopword\n",
    "\n",
    "    return filtered\n",
    "\n",
    "# =========================\n",
    "# STEMMING\n",
    "# =========================\n",
    "stem_factory = StemmerFactory()\n",
    "stemmer = stem_factory.create_stemmer()\n",
    "\n",
    "def stemming(tokens):\n",
    "\n",
    "    stemmed = [\n",
    "        stemmer.stem(word)\n",
    "        for word in tokens\n",
    "    ]   # stemming tiap token\n",
    "\n",
    "    return stemmed\n",
    "\n",
    "# =========================\n",
    "# APPLY PREPROCESSING\n",
    "# =========================\n",
    "text_column = \"full_text\"\n",
    "\n",
    "# 1. Case Folding\n",
    "df[\"casefold\"] = df[text_column].apply(case_folding)\n",
    "\n",
    "# 2. Cleaning\n",
    "df[\"cleaned\"] = df[\"casefold\"].apply(cleaning)\n",
    "\n",
    "# 3. Tokenization\n",
    "df[\"tokens\"] = df[\"cleaned\"].apply(tokenization)\n",
    "\n",
    "# 4. Stopword Removal\n",
    "df[\"stopword_removed\"] = df[\"tokens\"].apply(remove_stopwords)\n",
    "\n",
    "# 5. Stemming\n",
    "df[\"stemmed\"] = df[\"stopword_removed\"].apply(stemming)\n",
    "\n",
    "# 6. Final Text\n",
    "df[\"final_text\"] = df[\"stemmed\"].apply(lambda x: \" \".join(x))\n",
    "# gabungkan token kembali menjadi kalimat\n",
    "\n",
    "# =========================\n",
    "# FILTER FINAL (WAJIB)\n",
    "# =========================\n",
    "df = df[\n",
    "    df[\"final_text\"].notna() &             # buang NaN\n",
    "    (df[\"final_text\"].str.strip() != \"\") & # buang string kosong\n",
    "    (df[\"label\"] != \"HAPUS\")               # hapus label HAPUS\n",
    "]"
   ]
  },
