   "source": [
    "# TOP TERM TF-IDF TIAP LABEL\n",
    "\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from sklearn.feature_extraction.text import TfidfVectorizer\n",
    "\n",
    "# urutan label tetap\n",
    "labels = [\"Opini/Ekspresi\", \"Informasi\", \"Promosi\", \"Interaksi Fandom\"]\n",
    "\n",
    "# warna tiap label\n",
    "colors = {\"Opini/Ekspresi\": \"salmon\", \"Informasi\": \"plum\",\n",
    "    \"Promosi\": \"skyblue\", \"Interaksi Fandom\": \"lightgreen\"}\n",
    "\n",
    "# buat figure 2x2\n",
    "fig, axes = plt.subplots(2, 2, figsize=(16,12))\n",
    "\n",
    "# ubah jadi list agar mudah looping\n",
    "axes = axes.flatten()\n",
    "\n",
    "# looping tiap label\n",
    "for i, label in enumerate(labels):\n",
    "\n",
    "    # ambil data per label\n",
    "    subset = df[df[\"label\"] == label]\n",
    "\n",
    "    # TF-IDF\n",
    "    vectorizer = TfidfVectorizer(max_features=1000)\n",
    "\n",
    "    X = vectorizer.fit_transform(subset[\"final_text\"])\n",
    "\n",
    "    # rata-rata TF-IDF\n",
    "    mean_tfidf = X.mean(axis=0).A1\n",
    "\n",
    "    # nama term\n",
    "    terms = vectorizer.get_feature_names_out()\n",
    "\n",
    "    # dataframe TF-IDF\n",
    "    tfidf_df = pd.DataFrame({\"term\": terms, \"tfidf\": mean_tfidf})\n",
    "\n",
    "    # ambil top 15\n",
    "    top_terms = tfidf_df.sort_values(by=\"tfidf\", ascending=False).head(15)\n",
    "\n",
    "    # axis sesuai subplot\n",
    "    ax = axes[i]\n",
    "\n",
    "    # bar chart horizontal\n",
    "    bars = ax.barh(top_terms[\"term\"], top_terms[\"tfidf\"], color=colors[label])\n",
    "\n",
    "    # judul subplot\n",
    "    ax.set_title(label)\n",
    "\n",
    "    # label axis\n",
    "    ax.set_xlabel(\"TF-IDF\", fontsize=10)\n",
    "    ax.set_ylabel(\"Term\", fontsize=10)\n",
    "\n",
    "    # grid\n",
    "    ax.xaxis.grid(True, linestyle='--', alpha=0.7)\n",
    "\n",
    "    # tambah margin kanan\n",
    "    ax.margins(x=0.110)\n",
    "\n",
    "    # term terbesar di atas\n",
    "    ax.invert_yaxis()\n",
    "\n",
    "    # angka TF-IDF\n",
    "    for bar in bars:\n",
    "\n",
    "        width = bar.get_width()\n",
    "\n",
    "        ax.text(width + 0.0005, bar.get_y() + bar.get_height()/2,\n",
    "            f\"{width:.3f}\", va='center', fontsize=10)\n",
    "\n",
    "# judul utama\n",
    "fig.suptitle(\"Top 15 TF-IDF Terms pada Label\", fontsize=18)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  }
